{
  "title": "Kaizen Secretary",
  "uid": "kaizen-secretary",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total de Execuções",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(routine_executions_total)",
          "legendFormat": "execuções"
        }
      ]
    },
    {
      "id": 2,
      "title": "Taxa de Mensagens Enviadas",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 10, "h": 8 },
      "targets": [
        {
          "expr": "rate(messages_sent_total[5m])",
          "legendFormat": "{{routine}} - {{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Duração Média das Rotinas (s)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(routine_duration_seconds_sum[5m]) / rate(routine_duration_seconds_count[5m])",
          "legendFormat": "{{routine}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Mensagens por Status",
      "type": "piechart",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (messages_sent_total)",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
